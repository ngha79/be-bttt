# Environment Configuration Template

# Copy this file to .env and fill in your values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_PORT=1433
DB_NAME=task_management_db
DB_USER=sa
DB_PASSWORD=123456
DB_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=task_management_db;encrypt=true;trustServerCertificate=true


# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_PORT=8080
APP_NAME=Task Management System API
APP_VERSION=1.0.0

# ==========================================
# JWT CONFIGURATION
# ==========================================
# JWT Secret (minimum 32 characters for HS512)
JWT_SECRET=mySecretKeyForJWTTokenGenerationAndValidation1234567890

# JWT Expiration time in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION=86400000

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG
LOGGING_LEVEL_SPRING_SECURITY=INFO
LOGGING_PATTERN="%d{yyyy-MM-dd HH:mm:ss} - %msg%n"

# ==========================================
# DATASOURCE POOLING
# ==========================================
DATASOURCE_HIKARI_MAX_POOL_SIZE=20
DATASOURCE_HIKARI_MIN_IDLE=5
DATASOURCE_HIKARI_CONNECTION_TIMEOUT=20000
DATASOURCE_HIKARI_IDLE_TIMEOUT=300000

# ==========================================
# JPA/HIBERNATE CONFIGURATION
# ==========================================
# DDL Auto: validate, update, create, create-drop
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true
HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_SERVLET_CONTEXT_PATH=/
SERVER_COMPRESSION_ENABLED=true
SERVER_TOMCAT_MAX_CONNECTIONS=200
SERVER_SHUTDOWN=graceful

# ==========================================
# SPRING CONFIGURATION
# ==========================================
SPRING_JACKSON_DEFAULT_PROPERTY_INCLUSION=non_null
SPRING_JACKSON_SERIALIZATION_WRITE_DATES_AS_TIMESTAMPS=false

# ==========================================
# CORS CONFIGURATION (if needed)
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# ==========================================
# ACTUATOR CONFIGURATION (Optional)
# ==========================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# ==========================================
# DOCKER CONFIGURATION
# ==========================================
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=task-management-api
DOCKER_IMAGE_TAG=1.0.0

# ==========================================
# ENVIRONMENT
# ==========================================
# Values: development, staging, production
ENVIRONMENT=development
